{
  "name": "@omnilux/plugin-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building OmniLux plugins.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omnilux-tv/plugin-sdk.git"
  },
  "homepage": "https://github.com/omnilux-tv/plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/omnilux-tv/plugin-sdk/issues"
  },
  "keywords": [
    "omnilux",
    "plugin",
    "sdk",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1",
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build",
    "verify:package": "node ./scripts/verify-package.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "typescript": "^5.8.2"
  }
}
